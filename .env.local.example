# Copy this file to `.env.local` and fill in the two values to enable Cloud Mode.
# Local Mode (the default) does NOT need these — the app works offline without
# Supabase configured at all.
#
# Both values come from your Supabase project Settings → API.
# Only the *anon* key goes here. The service_role key must NEVER ship to the
# browser; this app deliberately has no server-side endpoint that holds it.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
